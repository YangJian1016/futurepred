FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_BASE_URL=http://localhost:8000
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=
JWT_SECRET=
JWT_EXPIRE_MINUTES=720
IMAGE_PROVIDER_ORDER=siliconflow,dashscope,pollinations
PLAN_B_ENABLED=true
PLAN_B_REFERENCE_MODEL=Qwen/Qwen-Image-Edit-2509

# 阿里云视觉智能开放平台 - 人脸属性识别
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_FACEBODY_ENDPOINT=facebody.cn-shanghai.aliyuncs.com

# SiliconFlow (国内可用，通常有免费额度)
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=black-forest-labs/FLUX.1-schnell

# 阿里 DashScope (国内可用，通常有免费额度)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=wanx2.1-t2i-turbo

# 智谱 (可选扩展通道)
ZHIPU_API_KEY=
ZHIPU_MODEL=cogview-3-flash

# 无 key 公共通道（不稳定，仅做兜底）
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt
IMAGE_MODEL=flux

# ==================== 生图稳定性与质量参数（推荐按此起步） ====================
# 并发生成槽位：越大吞吐越高，但更容易触发上游限流/超时；越小更稳但更慢
# 推荐值：8（活动现场 6~12）
# 最小值：1
# 最大值：64
GENERATION_CONCURRENCY=8

# 排队等待生成槽位的超时时间（秒）：越大越不容易超时失败，但单请求等待更久
# 推荐值：20（现场拥堵时可到 30）
# 最小值：1
# 最大值：120
GENERATION_WAIT_TIMEOUT_SECONDS=20

# 单次调用上游生图服务的 HTTP 超时（秒）：越大越能容忍慢响应，但失败回收更慢
# 推荐值：90
# 最小值：5
# 最大值：300
PROVIDER_HTTP_TIMEOUT_SECONDS=90

# 上游 provider 自动重试次数（网络抖动/5xx）：越大成功率更高，但总时延更长
# 推荐值：2（网络差可到 3）
# 最小值：0
# 最大值：5
PROVIDER_RETRY_ATTEMPTS=2

# provider 重试退避基数（秒）：越大越温和，越不容易压垮上游；但恢复更慢
# 推荐值：1.2
# 最小值：0.1
# 最大值：10.0
PROVIDER_RETRY_BACKOFF_SECONDS=1.2

# 可接受的最大输出图片字节数：越大可保留更多细节，但内存/带宽压力更高
# 推荐值：8388608 (8MB)
# 最小值：262144 (256KB)
# 最大值：20971520 (20MB)
MAX_IMAGE_BYTES=8388608

# 历史记录最大条数：越大可追溯越久，但磁盘占用更高
# 推荐值：5000
# 最小值：200
# 最大值：50000
HISTORY_MAX_RECORDS=5000

# ==================== 人脸质量门禁与“多次失败取最佳图”参数 ====================
# 质量重试次数（每次会换 seed 再生图）：越大越可能出好图，但更慢
# 推荐值：2（现场常用 2~3）
# 最小值：0
# 最大值：4
FACE_QUALITY_RETRY_ATTEMPTS=2

# 质量综合分最低阈值（0~100，越大越严格）：越大质量更好但更容易重试/失败
# 推荐值：45（现场建议 40~55）
# 最小值：0
# 最大值：100
FACE_QUALITY_MIN_SCORE=45

# Blur 质量分最低阈值（官方语义：越大越清晰，范围 0~100）
# 越大越严格；越小越宽松
# 推荐值：85（官方建议阈值）
# 最小值：0
# 最大值：100
FACE_QUALITY_MIN_BLUR_SCORE=85

# 多次重试仍不理想时，是否自动选择“最佳候选图”
# true：开启（推荐，活动现场更稳）
# false：关闭（全部不达标则直接失败）
FACE_BEST_PICK_ENABLED=true

# 最佳图打分里“综合质量分”的权重（0~1）
# 越大：更偏向 score；越小：更偏向 blur
# 推荐值：0.6
# 最小值：0
# 最大值：1
FACE_BEST_PICK_SCORE_WEIGHT=0.6

# 最佳图打分里“Blur 质量分”的权重（0~1）
# 越大：更偏向 blur；越小：更偏向 score
# 推荐值：0.4
# 最小值：0
# 最大值：1
FACE_BEST_PICK_BLUR_WEIGHT=0.4

# 说明：
# 1) 多次尝试都不理想时，系统会按加权得分选最优图。
# 2) 若性别不一致（gender mismatch），该候选图直接记 0 分，不会被选为最佳图。
