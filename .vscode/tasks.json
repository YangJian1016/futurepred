{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Frontend Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--prefix",
				"frontend"
			],
			"isBackground": true
		},
		{
			"label": "Run Backend API",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"uvicorn",
				"app.main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"8000",
				"--app-dir",
				"backend"
			],
			"isBackground": true
		}
	]
}